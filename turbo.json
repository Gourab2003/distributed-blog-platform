{
  "$schema": "https://turbo.build/schema.json",

  "globalDependencies": [
    "**/.env.*",
    "tsconfig.base.json"
  ],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": []
    },

    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },

    "clean": {
      "cache": false
    }
  }
}