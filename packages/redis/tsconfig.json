{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "incremental": true,

    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ],

  "references": [
    {
      "path": "../logger",
    },
    {
      "path": "../configuration"
    },
    {
      "path": "../errors"
    },
    {
      "path": "../runtime"
    }
  ]
}
