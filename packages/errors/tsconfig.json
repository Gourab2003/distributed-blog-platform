{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "incremental": true,

    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "ignoreDeprecations": "5.0"

  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
