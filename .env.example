# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blog_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blog_platform

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Service Ports ─────────────────────────────────────────────
PORT=3000

# ── Internal Service URLs ─────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
BLOG_SERVICE_URL=http://blog-service:3003
INTERACTION_SERVICE_URL=http://interaction-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3005

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
LOG_LEVEL=info
NODE_ENV=development