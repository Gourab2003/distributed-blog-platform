cat > .gitignore << 'EOF'
# dependencies
node_modules

# builds
dist
build
coverage
.turbo

# environment
.env
.env.*
!.env.example

# logs
logs
*.log
pnpm-debug.log*

# runtime
tmp
temp

# OS
.DS_Store
Thumbs.db

# IDE
.vscode
.idea

# docker
docker-data

# testing
playwright-report

# typescript
*.tsbuildinfo

# lockfiles
package-lock.json
yarn.lock

# misc
.cache
EOF